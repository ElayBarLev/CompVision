data/raw/
data/processed/
data/annotations/
weights/
outputs/figures/
outputs/metrics/
*.pt
*.pth
*.onnx
*.engine

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
