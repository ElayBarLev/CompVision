# ---- Data & model artifacts (large / regenerable - keep out of git) ----
data/raw/
data/processed/
data/annotations/
weights/
outputs/figures/
outputs/metrics/
*.pt
*.pth
*.onnx
*.engine

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

# ---- Kaggle / HF caches (can be huge) ----
.cache/
*.zip

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.vscode/
.idea/

# ---- Keep folder structure but not contents ----
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/annotations/.gitkeep
!weights/.gitkeep
!outputs/figures/.gitkeep
!outputs/metrics/.gitkeep

# ---- Bonus phone demo: the web models MUST be committed so GitHub Pages can serve them ----
# (overrides the global *.onnx ignore above; each ~72 MB, under GitHub's 100 MB limit)
# Same model (lr0025) baked at 3 resolutions — the live picker in web/index.html.
!web/model.onnx
!web/model_640.onnx
!web/model_800.onnx
